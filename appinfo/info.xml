<?xml version="1.0" encoding="utf-8"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
  <id>video_converter</id>
  <name>Video Converter</name>
  <summary>Convert videos from the Files menu</summary>
  <description>ExApp backend for ffmpeg conversion with WebDAV upload back to Nextcloud.</description>
  <version>1.0.2</version>
  <licence>Apache 2.0</licence>
  <author>kyasu-404</author>
  <category>multimedia</category>
  <dependencies>
    <nextcloud min-version="31"/>
  </dependencies>
  <port>8080</port>
  <secret>video_converter_secret_12345</secret>

  <external-app>
    <docker-install>
      <registry>ghcr.io</registry>
      <image>kyasu-404/nextcloud-video-converter</image>
      <image-tag>1.0.2</image-tag>
    </docker-install>

    <routes>
      <route>
        <url>^/heartbeat$</url>
        <verb>GET</verb>
        <access_level>PUBLIC</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>^/init$</url>
        <verb>POST</verb>
        <access_level>PUBLIC</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>^/enabled$</url>
        <verb>GET,PUT</verb>
        <access_level>PUBLIC</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>^/action/.*</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>^/api/.*</url>
        <verb>GET,POST,PUT,DELETE</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>^/ui/.*</url>
        <verb>GET</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
    </routes>

  </external-app>
</info>
